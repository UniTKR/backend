SPRING_PROFILES_ACTIVE=local
SPRING_APPLICATION_NAME=unit-backend
SERVER_PORT=8080
APP_TIME_ZONE=Asia/Seoul
APP_LOG_LEVEL=DEBUG

MYSQL_DATABASE=unit
MYSQL_USER=unit
MYSQL_PASSWORD=unit
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

DB_URL=jdbc:mysql://localhost:3306/unit?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=unit
DB_PASSWORD=unit
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=3000
DB_VALIDATION_TIMEOUT_MS=2000

JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true
JPA_DDL_AUTO=validate

FLYWAY_ENABLED=true
FLYWAY_LOCATIONS=classpath:db/migration
FLYWAY_BASELINE_ON_MIGRATE=false

JWT_ISSUER=unit-api
JWT_ACCESS_TOKEN_TTL=30m
JWT_REFRESH_TOKEN_TTL=14d
JWT_SECRET=change-this-local-dev-secret-change-this

UNIT_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=
